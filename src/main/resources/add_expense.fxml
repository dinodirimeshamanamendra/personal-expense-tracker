<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.AddExpenseController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <ComboBox fx:id="typeBox" promptText="Type" />
    <ComboBox fx:id="categoryBox" promptText="Category" />
    <TextField fx:id="amountField" promptText="Amount" />
    <DatePicker fx:id="datePicker" />
    <Button onAction="#saveExpense" text="Save" />

</VBox>
